APP_HOST=0.0.0.0
APP_PORT=8088
SESSION_SECRET=change-me-generate-with-secrets-token-urlsafe
DATABASE_URL=sqlite:///./data/support_kb.sqlite3
QDRANT_URL=http://qdrant:6333
COLLECTION_PREFIX=kb_
OPENAI_API_KEY=sk-placeholder-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# Chat/Agent auth: api_key (Platform API) or chatgpt_oauth (Codex/ChatGPT subscription)
LLM_AUTH_MODE=chatgpt_oauth
CHAT_MODEL=gpt-5.4-mini
# Used when LLM_AUTH_MODE=chatgpt_oauth (device login -> auth.json)
CODEX_AUTH_PATH=~/.codex/auth.json
CODEX_OAUTH_AUTH_PATH=~/.oauth_codex/auth.json
CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
TOP_K_DEFAULT=4
MIN_SCORE_DEFAULT=0.25
MAX_TOOL_ROUNDS=4
MAX_UPLOAD_MB=30
ALLOWED_EXTENSIONS=.txt,.md,.pdf,.docx
