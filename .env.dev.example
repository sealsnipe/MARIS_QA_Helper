# Copy to .env.dev for local dev on port 8090 (see scripts/dev_local.sh).
APP_HOST=0.0.0.0
APP_PORT=8088
SESSION_SECRET=dev-local-change-me-use-secrets-token-urlsafe-32
DATABASE_URL=sqlite:///./data-dev/support_kb.sqlite3
QDRANT_URL=http://127.0.0.1:6334
COLLECTION_PREFIX=kb_
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
LLM_AUTH_MODE=chatgpt_oauth
CHAT_MODEL=gpt-5.4-mini
CODEX_AUTH_PATH=~/.codex/auth.json
CODEX_OAUTH_AUTH_PATH=~/.oauth_codex/auth.json
CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
SESSION_COOKIE_SECURE=false
DEPLOY_PROFILE=dev
TOP_K_DEFAULT=4
MIN_SCORE_DEFAULT=0.25
MAX_TOOL_ROUNDS=4
MAX_UPLOAD_MB=30
ALLOWED_EXTENSIONS=.txt,.md,.pdf,.docx
